<Window x:Class="BusinessManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Alinda Brenda - Business Manager" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <materialDesign:ColorZone Grid.Row="0" 
                                  Mode="PrimaryMid" 
                                  Padding="16">
            <DockPanel>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        DockPanel.Dock="Left"
                        Click="MenuButton_Click"
                        Margin="0,0,16,0">
                    <materialDesign:PackIcon Kind="Menu"/>
                </Button>
                
                <TextBlock Text="Alinda Brenda"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"
                           Foreground="White"/>
                
                <StackPanel Orientation="Horizontal" 
                            DockPanel.Dock="Right">
                    <TextBlock x:Name="CurrentUserText"
                               Text="Admin"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               Foreground="White"/>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Click="LogoutButton_Click">
                        <materialDesign:PackIcon Kind="Logout"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sidebar -->
            <ScrollViewer Grid.Column="0" 
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidebarMenu" 
                            Margin="8">
                    <!-- Dashboard -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToDashboard"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Sales -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToSales"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PointOfSale" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Sales"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Expenses -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToExpenses"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Receipt" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Expenses"/>
                        </StackPanel>
                    </Button>

                    <!-- Debtors -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToDebtors"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCash"
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Debtors"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Inventory -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToInventory"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageVariant" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Inventory"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Reports -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToReports"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileChart" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Reports"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Settings -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToSettings"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Settings" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Users (Admin only) -->
                    <Button x:Name="UsersMenuButton"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToUsers"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Users"/>
                        </StackPanel>
                    </Button>
                    
                    <Separator Margin="8"/>
                    
                    <!-- Backup -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="NavigateToBackup"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BackupRestore" 
                                                   Margin="0,0,16,0"/>
                            <TextBlock Text="Backup &amp; Restore"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                          HorizontalAlignment="Stretch" 
                          Background="LightGray"/>
            
            <!-- Content Area -->
            <ContentControl x:Name="MainContent" 
                            Grid.Column="2"
                            Margin="8"/>
        </Grid>
    </Grid>
</Window>

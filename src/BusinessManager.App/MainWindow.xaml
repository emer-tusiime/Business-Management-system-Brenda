<Window x:Class="BusinessManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Alinda Brenda - Business Manager"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== TOP HEADER ===== -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Height="52" Margin="12,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Storefront" Width="24" Height="24"
                                             Foreground="White" VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                    <TextBlock Text="Alinda Brenda"
                               FontSize="17" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Account" Width="18" Height="18"
                                             Foreground="#BBDEFB" VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="CurrentUserText"
                               Text="Admin"
                               FontSize="13" Foreground="White" Opacity="0.9"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Click="LogoutButton_Click"
                            ToolTip="Logout" Foreground="White">
                        <materialDesign:PackIcon Kind="LogoutVariant" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="68"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== COMPACT ICON SIDEBAR ===== -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A237E" Offset="0"/>
                        <GradientStop Color="#283593" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="SidebarMenu" Margin="0,10,0,10">

                        <!-- Dashboard -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToDashboard"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Dashboard">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ViewDashboard"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Dashboard"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Point of Sale -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToSales"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Point of Sale">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PointOfSale"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Sales"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Expenses -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToExpenses"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Expenses">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Receipt"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Expenses"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Debtors -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToDebtors"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Debtors">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountCash"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Debtors"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="#30FFFFFF" Margin="10,8,10,8"/>

                        <!-- Inventory -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToInventory"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Inventory">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PackageVariant"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Inventory"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Reports -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToReports"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Reports">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileChart"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Reports"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="#30FFFFFF" Margin="10,8,10,8"/>

                        <!-- Settings -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToSettings"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Settings">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Settings"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Settings"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                        <!-- Backup -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Click="NavigateToBackup"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="58" Padding="0" Margin="0,1"
                                ToolTip="Backup &amp; Restore">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="BackupRestore"
                                                         Width="22" Height="22"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Backup"
                                           FontSize="8" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Opacity="0.85"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <ContentControl x:Name="MainContent" Grid.Column="1" Margin="0"/>
        </Grid>

        <!-- Toast notifications -->
        <materialDesign:Snackbar x:Name="MainSnackbar"
                                  Grid.Row="1"
                                  VerticalAlignment="Bottom"
                                  HorizontalAlignment="Stretch"
                                  MessageQueue="{materialDesign:MessageQueue}"/>
    </Grid>
</Window>

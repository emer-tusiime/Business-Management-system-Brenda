<UserControl x:Class="BusinessManager.App.Views.Orders.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1100"
             Background="#F1F5F9"
             Loaded="OrdersView_Loaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4A148C" Offset="0"/>
                    <GradientStop Color="#7B1FA2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ClipboardList" Width="26" Height="26"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Client Orders" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Track jobs submitted by clients" FontSize="11" Foreground="#CE93D8"/>
                    </StackPanel>
                </StackPanel>
                <!-- Status pills -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#B71C1C" CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                            Visibility="{Binding OverdueCount, Converter={StaticResource BoolVis}}">
                        <TextBlock Foreground="White" FontSize="12" FontWeight="Bold">
                            <Run Text="{Binding OverdueCount}"/><Run Text=" Overdue"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#E65100" CornerRadius="12" Padding="12,4" Margin="0,0,16,0"
                            Visibility="{Binding DueTodayCount, Converter={StaticResource BoolVis}}">
                        <TextBlock Foreground="White" FontSize="12" FontWeight="Bold">
                            <Run Text="{Binding DueTodayCount}"/><Run Text=" Due Today"/>
                        </TextBlock>
                    </Border>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding LoadCommand}" Foreground="White" ToolTip="Refresh">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- New order form -->
        <Border Grid.Row="1" Background="White" Margin="16,12,16,0" CornerRadius="10" Padding="16,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Register New Order" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Client Name *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewClientName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Phone"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Grid.Column="2" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Job Description *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="Pickup Date" FontSize="11" Foreground="#6B7280" Margin="4,0,0,2"/>
                        <DatePicker SelectedDate="{Binding NewPickupDate}"/>
                    </StackPanel>
                    <TextBox Grid.Column="4" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Notes"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="5" Command="{Binding SaveOrderCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4A148C" BorderBrush="#4A148C"
                            Foreground="White" Height="52" Padding="18,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="ADD ORDER" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Filter row -->
        <Border Grid.Row="2" Background="White" Margin="16,8,16,0" CornerRadius="8" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Show active orders only" IsChecked="{Binding ShowPendingOnly}"
                          Command="{Binding ToggleFilterCommand}" Margin="0,0,24,0"/>
            </StackPanel>
        </Border>

        <!-- Orders table -->
        <Border Grid.Row="3" Background="White" Margin="16,8,16,16" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Orders}"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                <Setter Property="Background" Value="#FFF5F5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDueToday}" Value="True">
                                <Setter Property="Background" Value="#FFFBF0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="130"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="110"/>
                    <DataGridTextColumn Header="Job Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate, StringFormat='d MMM'}" Width="90"/>
                    <DataGridTemplateColumn Header="Pickup Date" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding PickupDate, StringFormat='d MMM yyyy'}"/>
                                            <Setter Property="Foreground" Value="#374151"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDueToday}" Value="True">
                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Status" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3" Margin="4,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="2">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="3">
                                                    <Setter Property="Background" Value="#F3F4F6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3">
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.MarkReadyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Mark Ready for Pickup" Foreground="#2E7D32">
                                        <materialDesign:PackIcon Kind="CheckCircle" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.MarkDeliveredCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Mark Delivered" Foreground="#1565C0">
                                        <materialDesign:PackIcon Kind="PackageUp" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Delete" Foreground="#EF5350">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

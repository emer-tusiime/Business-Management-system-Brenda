<UserControl x:Class="BusinessManager.App.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F1F5F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== PAGE HEADER ===== -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0}'}"
                               FontSize="12" Foreground="#64748B"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding LoadDataCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        VerticalAlignment="Center"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refresh" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== SCROLLABLE CONTENT ===== -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24">

                <!-- ── TODAY'S PERFORMANCE ── -->
                <TextBlock Text="TODAY'S PERFORMANCE"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#64748B"
                           Margin="2,0,0,12"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TODAY INCOME – Blue -->
                    <Border Grid.Column="0" CornerRadius="12" Padding="20,18" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.22" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="1" Kind="TrendingUp"
                                                     Width="36" Height="36"
                                                     Foreground="White" Opacity="0.35"
                                                     VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TOTAL MADE TODAY"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding Summary.TodayIncome, StringFormat='{}{0:N0}'}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="White" Margin="0,8,0,0"/>
                                <TextBlock Text="UGX — all sales today"
                                           FontSize="11" Foreground="White" Opacity="0.65"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- TODAY EXPENSES – Red -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20,18" Margin="8,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#B71C1C" Offset="0"/>
                                <GradientStop Color="#EF5350" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.22" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="1" Kind="TrendingDown"
                                                     Width="36" Height="36"
                                                     Foreground="White" Opacity="0.35"
                                                     VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="EXPENSES TODAY"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding Summary.TodayExpenses, StringFormat='{}{0:N0}'}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="White" Margin="0,8,0,0"/>
                                <TextBlock Text="UGX — spent today"
                                           FontSize="11" Foreground="White" Opacity="0.65"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CASH IN DRAWER – Green -->
                    <Border Grid.Column="2" CornerRadius="12" Padding="20,18" Margin="8,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#1B5E20" Offset="0"/>
                                <GradientStop Color="#43A047" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.22" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="1" Kind="CashRegister"
                                                     Width="36" Height="36"
                                                     Foreground="White" Opacity="0.35"
                                                     VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CASH IN DRAWER"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding Summary.DrawerBalance, StringFormat='{}{0:N0}'}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="White" Margin="0,8,0,0"/>
                                <TextBlock Text="UGX — net balance"
                                           FontSize="11" Foreground="White" Opacity="0.65"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- OUTSTANDING DEBTS – Purple -->
                    <Border Grid.Column="3" CornerRadius="12" Padding="20,18" Margin="8,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#4A148C" Offset="0"/>
                                <GradientStop Color="#AB47BC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.22" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="1" Kind="AccountAlert"
                                                     Width="36" Height="36"
                                                     Foreground="White" Opacity="0.35"
                                                     VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="OUTSTANDING DEBTS"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White" Opacity="0.8"/>
                                <TextBlock Text="{Binding Summary.TotalOutstandingDebt, StringFormat='{}{0:N0}'}"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="White" Margin="0,8,0,0"/>
                                <TextBlock Text="UGX — credit owed"
                                           FontSize="11" Foreground="White" Opacity="0.65"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── WEEKLY + MONTHLY SUMMARY ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- This Week -->
                    <Border Grid.Column="0" CornerRadius="10" Background="White"
                            Margin="0,0,8,0" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="6" CornerRadius="3" Background="#1565C0"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="THIS WEEK"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Income" FontSize="13" Foreground="#374151"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Summary.ThisWeekIncome, StringFormat='{}{0:N0} UGX'}"
                                           FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Expenses" FontSize="13" Foreground="#374151"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Summary.ThisWeekExpenses, StringFormat='{}{0:N0} UGX'}"
                                           FontSize="14" FontWeight="Bold" Foreground="#C62828"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- This Month -->
                    <Border Grid.Column="1" CornerRadius="10" Background="White"
                            Margin="8,0,0,0" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="6" CornerRadius="3" Background="#2E7D32"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="THIS MONTH"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Income" FontSize="13" Foreground="#374151"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Summary.ThisMonthIncome, StringFormat='{}{0:N0} UGX'}"
                                           FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Expenses" FontSize="13" Foreground="#374151"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Summary.ThisMonthExpenses, StringFormat='{}{0:N0} UGX'}"
                                           FontSize="14" FontWeight="Bold" Foreground="#C62828"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── ANALYTICS CHARTS ── -->
                <TextBlock Text="ANALYTICS &amp; INSIGHTS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#64748B"
                           Margin="2,0,0,12"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="10" Background="White"
                            Margin="0,0,8,0" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Income by Service"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0F172A" Margin="0,0,0,14"/>
                            <lvc:PieChart Series="{Binding IncomeByModuleSeries}"
                                          Height="230"
                                          LegendPosition="Bottom"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="10" Background="White"
                            Margin="8,0,0,0" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Monthly Trend — 6 months"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0F172A" Margin="0,0,0,14"/>
                            <lvc:CartesianChart Series="{Binding MonthlyTrendSeries}"
                                                Height="230"
                                                XAxes="{Binding MonthlyTrendXAxes}"
                                                YAxes="{Binding MonthlyTrendYAxes}"
                                                LegendPosition="Bottom"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── CREDIT / DEBTORS ── -->
                <TextBlock Text="CREDIT &amp; DEBTORS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#64748B"
                           Margin="2,0,0,12"/>

                <Border CornerRadius="10" Background="White"
                        Padding="20,16" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Outstanding Credit"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0F172A" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Summary.TotalOutstandingDebt, StringFormat='{}{0:N0} UGX'}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#6A1B9A"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <DataGrid ItemsSource="{Binding Summary.CustomerDebts}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  MaxHeight="180"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Customer"
                                                    Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Phone"
                                                    Binding="{Binding Phone}" Width="120"/>
                                <DataGridTextColumn Header="Records"
                                                    Binding="{Binding OpenRecords}" Width="70"/>
                                <DataGridTextColumn Header="Amount Due"
                                                    Binding="{Binding TotalOwed, StringFormat='{}{0:N0} UGX'}"
                                                    Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ── QUICK ACTIONS ── -->
                <TextBlock Text="QUICK ACTIONS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#64748B"
                           Margin="2,0,0,12"/>

                <WrapPanel>
                    <Button Margin="0,0,10,10" Height="44" Padding="22,0"
                            Background="#1565C0" BorderBrush="#1565C0" Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="QuickAction_NewSale">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PointOfSale" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="New Sale" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,10" Height="44" Padding="22,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="QuickAction_AddExpense">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Receipt" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Expense" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,10" Height="44" Padding="22,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="QuickAction_Reports">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileChart" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,10" Height="44" Padding="22,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="QuickAction_Inventory">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageVariant" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Inventory" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="BusinessManager.App.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Dashboard"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"/>
                <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0}'}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Opacity="0.7"/>
            </StackPanel>
            
            <!-- Refresh Button -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Command="{Binding LoadDataCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" 
                                                Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        
        <!-- Summary Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Today's Summary -->
                <TextBlock Text="Today's Summary"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Today Income -->
                    <materialDesign:Card Grid.Column="0" 
                                         Margin="0,0,8,0"
                                         Background="LightBlue">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="TrendingUp" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Total Made Today"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.TodayIncome, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <TextBlock Text="All sales recorded today"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.7"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <!-- Today Expenses -->
                    <materialDesign:Card Grid.Column="1" 
                                         Margin="8,0,8,0"
                                         Background="LightCoral">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="TrendingDown" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Expenses Today"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.TodayExpenses, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <!-- Cash in Drawer -->
                    <materialDesign:Card Grid.Column="2" 
                                         Margin="8,0,0,0"
                                         Background="Gold">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="CashRegister" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Cash in Drawer"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.DrawerBalance, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <TextBlock Text="Sales today minus expenses"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.7"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
                
                <!-- Weekly Summary -->
                <TextBlock Text="This Week's Summary"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:Card Grid.Column="0" 
                                         Margin="0,0,8,0"
                                         Background="LightBlue">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="CalendarWeek" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Income This Week"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.ThisWeekIncome, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <materialDesign:Card Grid.Column="1" 
                                         Margin="8,0,0,0"
                                         Background="LightCoral">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="Receipt" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Expenses This Week"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.ThisWeekExpenses, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
                
                <!-- Monthly Summary -->
                <TextBlock Text="Monthly Summary"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:Card Grid.Column="0" 
                                         Margin="0,0,8,0"
                                         Background="LightBlue">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="CalendarMonth" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Income"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.ThisMonthIncome, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <materialDesign:Card Grid.Column="1" 
                                         Margin="8,0,0,0"
                                         Background="LightCoral">
                        <StackPanel Margin="16">
                            <materialDesign:PackIcon Kind="Receipt" 
                                                    Width="24" Height="24"
                                                    Margin="0,0,0,8"/>
                            <TextBlock Text="Expenses"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Summary.ThisMonthExpenses, StringFormat='{}{0:N0} UGX'}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Debtors Summary -->
                <TextBlock Text="Credit / Debtors"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,16"/>

                <materialDesign:Card Margin="0,0,0,24">
                    <StackPanel Margin="16">
                        <TextBlock Text="{Binding Summary.TotalOutstandingDebt, StringFormat='Total outstanding credit: {0:N0} UGX'}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding Summary.CustomerDebts}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                                <DataGridTextColumn Header="Records" Binding="{Binding OpenRecords}" Width="70"/>
                                <DataGridTextColumn Header="Amount Due" Binding="{Binding TotalOwed, StringFormat='{}{0:N0} UGX'}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
                
                <!-- Charts Section -->
                <TextBlock Text="Analytics &amp; Insights"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Income by Module Chart -->
                    <materialDesign:Card Grid.Column="0" 
                                         Margin="0,0,8,0">
                        <StackPanel Margin="16">
                            <TextBlock Text="Income by Module"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       Margin="0,0,0,16"/>
                            
                            <lvc:PieChart 
                                Series="{Binding IncomeByModuleSeries}"
                                Width="300"
                                Height="250"
                                LegendPosition="Bottom"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <!-- Monthly Trend Chart -->
                    <materialDesign:Card Grid.Column="1" 
                                         Margin="8,0,0,0">
                        <StackPanel Margin="16">
                            <TextBlock Text="Monthly Trend"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       Margin="0,0,0,16"/>
                            
                            <lvc:CartesianChart 
                                Series="{Binding MonthlyTrendSeries}"
                                Width="300"
                                Height="250"
                                XAxes="{Binding MonthlyTrendXAxes}"
                                YAxes="{Binding MonthlyTrendYAxes}"
                                LegendPosition="Bottom"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
                
                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,24,0,16"/>
                
                <WrapPanel>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,8"
                            Click="QuickAction_NewSale">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PointOfSale"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="New Sale"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,8"
                            Click="QuickAction_AddExpense">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Receipt"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Add Expense"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,8"
                            Click="QuickAction_Reports">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileChart"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Reports"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,8"
                            Click="QuickAction_Inventory">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageVariant"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Inventory"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

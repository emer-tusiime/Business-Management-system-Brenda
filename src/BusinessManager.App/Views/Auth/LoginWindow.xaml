<Window x:Class="BusinessManager.App.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Brenda's Printing Hub"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0F1E" Offset="0"/>
            <GradientStop Color="#0D1B3E" Offset="0.55"/>
            <GradientStop Color="#1A237E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <!-- Decorative circles -->
        <Ellipse Width="500" Height="500" Opacity="0.04" Fill="White"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-200,-200,0" IsHitTestVisible="False"/>
        <Ellipse Width="320" Height="320" Opacity="0.04" Fill="White"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-140,0,0,-120" IsHitTestVisible="False"/>

        <!-- Login card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="400" CornerRadius="18" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0" Color="#000000" Opacity="0.35"/>
            </Border.Effect>

            <StackPanel>
                <!-- Top accent bar -->
                <Border CornerRadius="18,18,0,0" Height="6">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A237E" Offset="0"/>
                            <GradientStop Color="#42A5F5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Margin="40,28,40,36">

                    <!-- Logo circle -->
                    <Border Width="88" Height="88" CornerRadius="44"
                            HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1B3E" Offset="0"/>
                                <GradientStop Color="#1A237E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="CompanyLogo"
                                   Width="58" Height="58"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                            <materialDesign:PackIcon x:Name="FallbackIcon"
                                                     Kind="PrinterOutline"
                                                     Width="44" Height="44"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Company name -->
                    <TextBlock Text="BRENDA'S PRINTING HUB"
                               FontSize="19" FontWeight="Bold"
                               Foreground="#0D1B3E"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Business Management System"
                               FontSize="12" Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,24"/>

                    <!-- Username -->
                    <TextBlock Text="USERNAME"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#374151"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameTextBox"
                             materialDesign:HintAssist.Hint="Enter your username"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14"
                             Margin="0,0,0,18"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="PasswordBox_KeyDown"/>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#374151"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 materialDesign:HintAssist.Hint="Enter your password"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 FontSize="14"
                                 Margin="0,0,0,16"
                                 KeyDown="PasswordBox_KeyDown"/>

                    <!-- Error message -->
                    <Border CornerRadius="8"
                            Background="#FEF2F2"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            Padding="12,10"
                            Margin="0,0,0,14"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                     Width="16" Height="16"
                                                     Foreground="#DC2626"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#DC2626"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Loading bar -->
                    <ProgressBar IsIndeterminate="True"
                                 Margin="0,0,0,10"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Sign In button -->
                    <Button Height="50"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Click="LoginButton_Click"
                            IsDefault="True"
                            materialDesign:ElevationAssist.Elevation="Dp4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#0D1B3E"/>
                                <Setter Property="BorderBrush" Value="#0D1B3E"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Login" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="SIGN IN"/>
                        </StackPanel>
                    </Button>

                    <!-- Footer -->
                    <TextBlock Text="© 2026 Brenda's Printing Hub"
                               FontSize="10" Foreground="#9CA3AF"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

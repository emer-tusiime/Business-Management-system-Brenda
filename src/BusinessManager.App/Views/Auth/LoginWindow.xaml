<Window x:Class="BusinessManager.App.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Alinda Brenda - Business Manager"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Dark branded panel ===== -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A1628" Offset="0"/>
                    <GradientStop Color="#1A237E" Offset="0.5"/>
                    <GradientStop Color="#283593" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative background circles -->
            <Ellipse Width="520" Height="520" Fill="#FFFFFF" Opacity="0.03"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-220,-200,0,0" IsHitTestVisible="False"/>
            <Ellipse Width="380" Height="380" Fill="#FFFFFF" Opacity="0.03"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-150,-150" IsHitTestVisible="False"/>
            <Ellipse Width="160" Height="160" Fill="#64B5F6" Opacity="0.06"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,120,80,0" IsHitTestVisible="False"/>

            <!-- Branding content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="80,0">

                <!-- Icon ring -->
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="#2BFFFFFF"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,36">
                    <materialDesign:PackIcon Kind="Storefront"
                                             Width="62" Height="62"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Alinda Brenda"
                           FontSize="46" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Business Management System"
                           FontSize="16" Foreground="White" Opacity="0.65"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,52"/>

                <!-- Divider -->
                <Rectangle Height="1" Fill="#50FFFFFF" Margin="0,0,0,44"/>

                <!-- Feature list -->
                <StackPanel HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Ellipse Width="7" Height="7" Fill="#64B5F6"
                                 VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Point of Sale &amp; Sales Tracking"
                                   Foreground="White" Opacity="0.78" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Ellipse Width="7" Height="7" Fill="#64B5F6"
                                 VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Expense Management &amp; Reports"
                                   Foreground="White" Opacity="0.78" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Ellipse Width="7" Height="7" Fill="#64B5F6"
                                 VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Inventory &amp; Stock Control"
                                   Foreground="White" Opacity="0.78" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#64B5F6"
                                 VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Debtors &amp; Payment Tracking"
                                   Foreground="White" Opacity="0.78" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ===== RIGHT: Login form panel ===== -->
        <Grid Grid.Column="1" Background="#F8FAFC">

            <!-- Centered form -->
            <StackPanel VerticalAlignment="Center" Margin="64,0">

                <TextBlock Text="Welcome Back"
                           FontSize="34" FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Sign in to your account to continue"
                           FontSize="14" Foreground="#64748B"
                           Margin="0,0,0,44"/>

                <!-- Username -->
                <TextBlock Text="Username"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="2,0,0,6"/>
                <TextBox x:Name="UsernameTextBox"
                         materialDesign:HintAssist.Hint="Enter your username"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,22"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="PasswordBox_KeyDown"/>

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="2,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Enter your password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             FontSize="14"
                             Margin="0,0,0,10"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error message -->
                <Border CornerRadius="6"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        Padding="14,10"
                        Margin="0,0,0,22"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                 Width="16" Height="16"
                                                 Foreground="#DC2626"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Sign in button -->
                <Button Content="SIGN IN"
                        Height="50"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#1A237E"
                        BorderBrush="#1A237E"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="LoginButton_Click"
                        IsDefault="True"/>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Text="© 2026 Alinda Brenda — Business Manager"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,28"
                       FontSize="12"
                       Foreground="#94A3B8"/>
        </Grid>
    </Grid>
</Window>

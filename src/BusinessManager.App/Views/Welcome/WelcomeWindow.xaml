<Window x:Class="BusinessManager.App.Views.Welcome.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Welcome - Alinda Brenda" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <materialDesign:ColorZone Grid.Row="0" 
                                  Mode="PrimaryMid" 
                                  Padding="24">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Alinda Brenda"
                           Style="{StaticResource MaterialDesignHeadline3TextBlock}"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Business Management System"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Opacity="0.8"/>
            </StackPanel>
        </materialDesign:ColorZone>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Logo Placeholder -->
            <Border Grid.Row="0" 
                    Width="120" 
                    Height="120" 
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    CornerRadius="60"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24">
                <materialDesign:PackIcon Kind="Store" 
                                        Width="60" 
                                        Height="60" 
                                        Foreground="White"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
            </Border>
            
            <!-- Welcome Text -->
            <StackPanel Grid.Row="1" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Welcome to Alinda Brenda"
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                
                <TextBlock Text="Your complete solution for managing"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           HorizontalAlignment="Center"
                           Opacity="0.7"/>
                <TextBlock Text="stationery and retail business operations"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           HorizontalAlignment="Center"
                           Opacity="0.7"
                           Margin="0,0,0,24"/>
                
                <!-- Features -->
                <StackPanel Margin="0,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                                Foreground="Green"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Sales and Transaction Management"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </Grid>
                    
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                                Foreground="Green"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Expense Tracking and Reporting"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </Grid>
                    
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                                Foreground="Green"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Inventory Management"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </Grid>
                    
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                                Foreground="Green"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Financial Reports and Analytics"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
            
            <!-- Date/Time -->
            <TextBlock Grid.Row="2" 
                       x:Name="DateTimeText"
                       Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dddd, MMMM dd, yyyy HH:mm:ss}'}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
        </Grid>
        
        <!-- Footer -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,24,0,24">
            <Button x:Name="ContinueButton"
                    Content="Continue"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="120"
                    Click="ContinueButton_Click"/>
            <Button Content="Exit"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="120"
                    Margin="16,0,0,0"
                    Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

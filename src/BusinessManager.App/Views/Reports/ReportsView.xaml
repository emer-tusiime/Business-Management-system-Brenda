<UserControl x:Class="BusinessManager.App.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="800" d:DesignWidth="1200"
             Loaded="ReportsView_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1565C0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FileChart" Width="26" Height="26"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Reports &amp; Analytics"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Generate and print professional PDF reports for your business"
                                   FontSize="11" Foreground="#90CAF9"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT: Generator Panel ===== -->
                <StackPanel Grid.Column="0">

                    <!-- Step 1: Report Type -->
                    <materialDesign:Card Padding="0" Margin="0,0,0,14">
                        <StackPanel>
                            <Border Background="#0D47A1" Padding="16,10">
                                <TextBlock Text="STEP 1 — REPORT TYPE"
                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <StackPanel Margin="16,14">
                                <RadioButton Content="Financial Summary"
                                             GroupName="rptType"
                                             IsChecked="{Binding SelectedReportType, Converter={StaticResource StringEqualityConverter}, ConverterParameter='Financial'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,8"/>
                                <TextBlock Text="Income vs expenses, net profit, income breakdown by service &amp; product."
                                           FontSize="11" Foreground="#6B7280" Margin="28,0,0,12" TextWrapping="Wrap"/>

                                <RadioButton Content="Sales Report"
                                             GroupName="rptType"
                                             IsChecked="{Binding SelectedReportType, Converter={StaticResource StringEqualityConverter}, ConverterParameter='Sales'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,8"/>
                                <TextBlock Text="Financial summary + complete list of all sales transactions."
                                           FontSize="11" Foreground="#6B7280" Margin="28,0,0,12" TextWrapping="Wrap"/>

                                <RadioButton Content="Expenses Report"
                                             GroupName="rptType"
                                             IsChecked="{Binding SelectedReportType, Converter={StaticResource StringEqualityConverter}, ConverterParameter='Expenses'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,4"/>
                                <TextBlock Text="Financial summary + all expense entries broken down by category."
                                           FontSize="11" Foreground="#6B7280" Margin="28,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Step 2: Period -->
                    <materialDesign:Card Padding="0" Margin="0,0,0,14">
                        <StackPanel>
                            <Border Background="#1565C0" Padding="16,10">
                                <TextBlock Text="STEP 2 — PERIOD"
                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <StackPanel Margin="16,14">
                                <RadioButton Content="Today"
                                             GroupName="period"
                                             IsChecked="{Binding SelectedPeriod, Converter={StaticResource StringEqualityConverter}, ConverterParameter='Today'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="This Week"
                                             GroupName="period"
                                             IsChecked="{Binding SelectedPeriod, Converter={StaticResource StringEqualityConverter}, ConverterParameter='This Week'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="This Month"
                                             GroupName="period"
                                             IsChecked="{Binding SelectedPeriod, Converter={StaticResource StringEqualityConverter}, ConverterParameter='This Month'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="Custom Date Range"
                                             GroupName="period"
                                             IsChecked="{Binding SelectedPeriod, Converter={StaticResource StringEqualityConverter}, ConverterParameter='Custom'}"
                                             Style="{StaticResource MaterialDesignRadioButton}"
                                             Margin="0,0,0,4"/>

                                <!-- Custom date pickers -->
                                <StackPanel Margin="28,8,0,0"
                                            Visibility="{Binding ShowCustomDates, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DatePicker materialDesign:HintAssist.Hint="Start Date"
                                                SelectedDate="{Binding CustomStartDate}"
                                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                Margin="0,0,0,8"/>
                                    <DatePicker materialDesign:HintAssist.Hint="End Date"
                                                SelectedDate="{Binding CustomEndDate}"
                                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Step 3: Generate -->
                    <materialDesign:Card Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="STEP 3 — GENERATE" FontSize="11" FontWeight="Bold"
                                       Foreground="#374151" Margin="0,0,0,14"/>

                            <!-- Generate & Open -->
                            <Button Command="{Binding GenerateAndOpenCommand}"
                                    Height="50" Margin="0,0,0,10">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#0D47A1"/>
                                        <Setter Property="BorderBrush" Value="#0D47A1"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp4"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdf" Width="22" Height="22"
                                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Generate &amp; Open PDF" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <!-- Save only -->
                            <Button Command="{Binding GenerateAndSaveCommand}"
                                    Height="44"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#374151" BorderBrush="#CBD5E1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Save PDF (without opening)" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <!-- Progress -->
                            <ProgressBar IsIndeterminate="True" Margin="0,10,0,0"
                                         Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Status text -->
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#6B7280"
                                       TextWrapping="Wrap" Margin="0,8,0,0"
                                       Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Company info note -->
                    <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                            CornerRadius="6" Padding="14,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="Office" Width="14" Height="14"
                                                          Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="PDF reports are branded with:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#92400E"/>
                            </StackPanel>
                            <TextBlock Text="BRENDA'S PRINTING HUB" FontSize="12" FontWeight="Bold"
                                       Foreground="#1A237E"/>
                            <TextBlock Text="Katwe-Kevina road  ·  0703699727  ·  brelinda65@gmail.com"
                                       FontSize="10" Foreground="#555555"/>
                            <TextBlock Text="Saved to: Documents\BrendaBusinessReports\"
                                       FontSize="10" Foreground="#777777" FontFamily="Consolas" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ===== RIGHT: Recent Reports ===== -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Last report highlight card -->
                    <materialDesign:Card Grid.Row="0" Margin="0,0,0,14"
                                         Visibility="{Binding LastReport, Converter={StaticResource NullToCollapsedConverter}}">
                        <Grid Margin="18,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                    Background="#DCFCE7" Margin="0,0,14,0">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="28" Height="28"
                                                          Foreground="#16A34A"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="READY" FontSize="9" FontWeight="Bold"
                                           Foreground="#16A34A"/>
                                <TextBlock Text="{Binding LastReport.Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#111827" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                <TextBlock Foreground="#9CA3AF" FontSize="11">
                                    <Run Text="{Binding LastReport.GeneratedAtText}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding LastReport.SizeText}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#0D47A1" BorderBrush="#0D47A1" Foreground="White"
                                        Command="{Binding OpenReportCommand}"
                                        CommandParameter="{Binding LastReport}"
                                        Height="36" Padding="12,0" Margin="0,0,6,0" FontSize="12">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="OpenInNew" Width="16" Height="16"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Open"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#374151" BorderBrush="#CBD5E1"
                                        Command="{Binding PrintReportCommand}"
                                        CommandParameter="{Binding LastReport}"
                                        Height="36" Padding="12,0" FontSize="12">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Printer" Width="16" Height="16"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Print"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Reports list -->
                    <materialDesign:Card Grid.Row="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0"
                                    BorderThickness="0,0,0,1" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="History" Width="18" Height="18"
                                                              Foreground="#374151" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Reports Generated This Session" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#374151"/>
                                </StackPanel>
                            </Border>

                            <!-- Empty state -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Margin="0,50"
                                        Visibility="{Binding RecentReports.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                                <materialDesign:PackIcon Kind="FileDocumentOutline" Width="72" Height="72"
                                                          Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                                <TextBlock Text="No reports generated yet"
                                           FontSize="16" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center" Margin="0,16,0,6"/>
                                <TextBlock Text="Use the form on the left to generate your first report."
                                           FontSize="12" Foreground="#C4C9D0"
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           TextWrapping="Wrap" MaxWidth="300"/>
                            </StackPanel>

                            <!-- List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RecentReports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="8"
                                                            Background="#FEF2F2" Margin="0,0,12,0">
                                                        <materialDesign:PackIcon Kind="FilePdf" Width="24" Height="24"
                                                                                  Foreground="#EF4444"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#1F2937"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0">
                                                            <Run Text="{Binding GeneratedAtText}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding SizeText}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Command="{Binding DataContext.OpenReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Open PDF" Foreground="#0D47A1">
                                                            <materialDesign:PackIcon Kind="OpenInNew" Width="18" Height="18"/>
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Command="{Binding DataContext.PrintReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Print" Foreground="#374151">
                                                            <materialDesign:PackIcon Kind="Printer" Width="18" Height="18"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

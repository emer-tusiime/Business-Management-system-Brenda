<UserControl x:Class="BusinessManager.App.Views.Inventory.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="800" d:DesignWidth="1200"
             Loaded="InventoryView_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <materialDesign:ColorZone Grid.Row="0" 
                                  Mode="PrimaryMid" 
                                  Padding="16"
                                  Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           Text="Inventory Management"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           Foreground="White"/>
                
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding RefreshCommand}"
                            Foreground="White"
                            Margin="0,0,8,0">
                        <materialDesign:PackIcon Kind="Refresh"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Products List -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Filters -->
                <materialDesign:Card Grid.Row="0" Margin="0,0,0,8">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Search products..."
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            
                            <CheckBox Grid.Column="1"
                                      Content="Low Stock Only"
                                      IsChecked="{Binding ShowLowStockOnly}"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                        </Grid>
                    </Grid>
                </materialDesign:Card>
                
                <!-- Products DataGrid -->
                <materialDesign:Card Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" 
                                                Binding="{Binding Name}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Description" 
                                                Binding="{Binding Description}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Current Stock" 
                                                Binding="{Binding CurrentStock}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Reorder Level" 
                                                Binding="{Binding ReorderLevel}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Selling Price" 
                                                Binding="{Binding SellingPrice, StringFormat='{}{0:N0}'}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cost Price" 
                                                Binding="{Binding CostPrice, StringFormat='{}{0:N0}'}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Stock Value" 
                                                Binding="{Binding StockValue, StringFormat='{}{0:N0}'}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding IsLowStock, Converter={StaticResource StockStatusToColorConverter}}"
                                                CornerRadius="12"
                                                Padding="8,4"
                                                Margin="4">
                                            <TextBlock Text="{Binding IsLowStock, Converter={StaticResource StockStatusToTextConverter}}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>
            </Grid>
            
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                          HorizontalAlignment="Stretch" 
                          Background="LightGray"/>
            
            <!-- Right: Stock Management -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Stock Movement Form -->
                <materialDesign:Card Grid.Row="0" Margin="0,0,0,8">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Stock Movement"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <TextBlock Text="{Binding SelectedProduct.Name, StringFormat='Product: {0}'}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        
                        <!-- Movement Type -->
                        <ComboBox Grid.Row="1"
                                  materialDesign:HintAssist.Hint="Movement Type"
                                  SelectedItem="{Binding MovementType}"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem>StockIn</ComboBoxItem>
                            <ComboBoxItem>StockOut</ComboBoxItem>
                            <ComboBoxItem>Adjustment</ComboBoxItem>
                        </ComboBox>
                        
                        <!-- Quantity -->
                        <TextBox Grid.Row="2"
                                 materialDesign:HintAssist.Hint="Quantity"
                                 Text="{Binding MovementQuantity}"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        
                        <!-- Unit Cost -->
                        <TextBox Grid.Row="3"
                                 materialDesign:HintAssist.Hint="Unit Cost"
                                 Text="{Binding MovementUnitCost}"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        
                        <!-- Description -->
                        <TextBox Grid.Row="4"
                                 materialDesign:HintAssist.Hint="Description"
                                 Text="{Binding MovementDescription}"
                                 Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="60"/>
                        
                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,8">
                            <Button Content="Add Stock"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding AddStockCommand}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Remove Stock"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding RemoveStockCommand}"
                                    Margin="0,0,4,0"/>
                            <Button Content="Adjust"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AdjustStockCommand}"/>
                        </StackPanel>
                        
                        <!-- Product Info -->
                        <Border Grid.Row="6" 
                                Background="{DynamicResource MaterialDesignDividerBackground}"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Current Stock Information"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedProduct.CurrentStock, StringFormat='Current Stock: {0} units'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                <TextBlock Text="{Binding SelectedProduct.ReorderLevel, StringFormat='Reorder Level: {0} units'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                <TextBlock Text="{Binding SelectedProduct.StockValue, StringFormat='Stock Value: {0:N0}'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
                
                <!-- Movement History -->
                <materialDesign:Card Grid.Row="1">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0"
                                   Text="Movement History"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   Margin="0,0,0,8"/>
                        
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Movements}"
                                  SelectedItem="{Binding SelectedMovement}"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" 
                                                    Binding="{Binding MovementDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Type" 
                                                    Binding="{Binding MovementType}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Quantity" 
                                                    Binding="{Binding Quantity}"
                                                    Width="70"/>
                                <DataGridTextColumn Header="Before" 
                                                    Binding="{Binding StockBefore}"
                                                    Width="60"/>
                                <DataGridTextColumn Header="After" 
                                                    Binding="{Binding StockAfter}"
                                                    Width="60"/>
                                <DataGridTextColumn Header="User" 
                                                    Binding="{Binding UserName}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

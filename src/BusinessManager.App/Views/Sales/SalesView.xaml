<UserControl x:Class="BusinessManager.App.Views.Sales.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="900" d:DesignWidth="1400"
             Loaded="SalesView_Loaded">

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="PointOfSale" Width="28" Height="28"
                                             Foreground="White" VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>
                    <TextBlock Text="Point of Sale"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding RefreshCommand}"
                        Foreground="White" ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- =========================================
                 LEFT: Item catalog + sales history
                 ========================================= -->
            <Grid Grid.Column="0" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="270"/>
                </Grid.RowDefinitions>

                <!-- Catalog scroll area -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14,14,14,0">
                    <StackPanel>

                        <!-- SERVICES section -->
                        <TextBlock Text="SERVICES"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#64748B"
                                   Margin="4,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding ServiceItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="168" Height="86"
                                            Margin="0,0,10,10"
                                            Background="#1565C0"
                                            BorderBrush="#0D47A1"
                                            Foreground="White"
                                            Command="{Binding DataContext.AddServiceItemCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignRaisedButton}">
                                        <StackPanel HorizontalAlignment="Center" Margin="4,0">
                                            <materialDesign:PackIcon Kind="Flash"
                                                                     Width="22" Height="22"
                                                                     HorizontalAlignment="Center"
                                                                     Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="148"/>
                                            <TextBlock Text="{Binding DefaultPrice, StringFormat='{}{0:N0} UGX'}"
                                                       FontSize="11" Opacity="0.82"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- PRODUCTS section -->
                        <TextBlock Text="PRODUCTS"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#64748B"
                                   Margin="4,10,0,10"/>

                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="155" Height="82"
                                            Margin="0,0,10,10"
                                            Background="#00695C"
                                            BorderBrush="#004D40"
                                            Foreground="White"
                                            Command="{Binding DataContext.AddProductCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignRaisedButton}">
                                        <StackPanel HorizontalAlignment="Center" Margin="4,0">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,4">
                                                <materialDesign:PackIcon Kind="PackageVariantClosed"
                                                                         Width="15" Height="15"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,5,0" Opacity="0.85"/>
                                                <TextBlock Text="{Binding CurrentStock, StringFormat='Stk: {0}'}"
                                                           FontSize="10" Opacity="0.8"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="138"/>
                                            <TextBlock Text="{Binding SellingPrice, StringFormat='{}{0:N0} UGX'}"
                                                       FontSize="11" Opacity="0.82"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- SALES HISTORY strip -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- History header + totals -->
                        <Grid Grid.Row="0" Margin="14,10,14,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="History"
                                                         Width="17" Height="17"
                                                         Foreground="#64748B"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"/>
                                <TextBlock Text="SALES HISTORY"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HistoryTransactionCount, StringFormat='{}{0} txns'}"
                                           FontSize="12" Foreground="#475569"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding HistoryTotalAmount, StringFormat='{}{0:N0} UGX'}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1565C0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Compact filter bar -->
                        <Grid Grid.Row="1" Margin="10,0,10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0"
                                        materialDesign:HintAssist.Hint="From"
                                        SelectedDate="{Binding FilterStartDate}"
                                        FontSize="11"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            <DatePicker Grid.Column="2"
                                        materialDesign:HintAssist.Hint="To"
                                        SelectedDate="{Binding FilterEndDate}"
                                        FontSize="11"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            <TextBox Grid.Column="4"
                                     materialDesign:HintAssist.Hint="Search..."
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="6"
                                    Content="Filter"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Height="30" Padding="14,0" FontSize="11"/>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Sales}"
                                  SelectedItem="{Binding SelectedSale}"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  FontSize="12"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Receipt #"
                                                    Binding="{Binding ReceiptNumber}"
                                                    Width="110"/>
                                <DataGridTextColumn Header="Date / Time"
                                                    Binding="{Binding SaleDate, StringFormat='{}{0:dd/MM HH:mm}'}"
                                                    Width="110"/>
                                <DataGridTextColumn Header="Customer"
                                                    Binding="{Binding CustomerName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Total (UGX)"
                                                    Binding="{Binding TotalAmount, StringFormat='{}{0:N0}'}"
                                                    Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#1565C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="44">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.DeleteSaleCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="30" Height="30"
                                                    ToolTip="Delete">
                                                <materialDesign:PackIcon Kind="DeleteOutline"
                                                                         Width="16" Height="16"
                                                                         Foreground="#DC2626"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                </Border>
            </Grid>

            <!-- =========================================
                 RIGHT: Cart panel
                 ========================================= -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cart header -->
                    <Border Grid.Row="0"
                            Padding="18,14"
                            BorderBrush="#F1F5F9"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Cart"
                                                         Width="22" Height="22"
                                                         Foreground="#1565C0"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <TextBlock Text="Current Order"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentSaleItems.Count, StringFormat='{}{0} item(s)'}"
                                       FontSize="12" Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Cart items area -->
                    <Grid Grid.Row="1">
                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSaleItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CartOutline"
                                                     Width="52" Height="52"
                                                     Foreground="#CBD5E1"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,0,0,12"/>
                            <TextBlock Text="Cart is empty"
                                       FontSize="14" Foreground="#94A3B8"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Tap a service or product to add it"
                                       FontSize="12" Foreground="#CBD5E1"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Items list -->
                        <ListBox ItemsSource="{Binding CurrentSaleItems}"
                                 SelectedItem="{Binding SelectedSaleItem}"
                                 HorizontalContentAlignment="Stretch"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSaleItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="16,12"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="#0F172A"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat='Qty: {0}'}"
                                                       FontSize="11" Foreground="#94A3B8"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalPrice, StringFormat='{}{0:N0}'}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#1565C0"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,6,0"/>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.RemoveSaleItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="26" Height="26" Padding="0">
                                            <materialDesign:PackIcon Kind="Close"
                                                                     Width="14" Height="14"
                                                                     Foreground="#94A3B8"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Cart footer: customer + total + buttons -->
                    <Border Grid.Row="2"
                            Padding="16,14"
                            BorderBrush="#F1F5F9"
                            BorderThickness="0,1,0,0">
                        <StackPanel>

                            <!-- Customer name (optional) -->
                            <TextBox materialDesign:HintAssist.Hint="Customer name (optional)"
                                     Text="{Binding CustomerName}"
                                     FontSize="13"
                                     Margin="0,0,0,14"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                            <!-- Total display -->
                            <Border Background="#EFF6FF"
                                    CornerRadius="8"
                                    Padding="16,14"
                                    Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="TOTAL"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#1E3A5F"/>
                                        <TextBlock Text="UGX"
                                                   FontSize="10" Foreground="#64748B"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"
                                               FontSize="30" FontWeight="Bold"
                                               Foreground="#1565C0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Action buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="CLEAR"
                                        Height="46" FontSize="12" FontWeight="Bold"
                                        Background="#FEE2E2"
                                        BorderBrush="#FEE2E2"
                                        Foreground="#DC2626"
                                        Command="{Binding ClearSaleCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                                <Button Grid.Column="2"
                                        Content="SAVE SALE"
                                        Height="46" FontSize="13" FontWeight="Bold"
                                        Background="#1565C0"
                                        BorderBrush="#1565C0"
                                        Foreground="White"
                                        Command="{Binding SaveSaleCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

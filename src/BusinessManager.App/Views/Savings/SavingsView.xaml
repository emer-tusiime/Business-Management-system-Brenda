<UserControl x:Class="BusinessManager.App.Views.Savings.SavingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1100"
             Background="#F1F5F9"
             Loaded="SavingsView_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1B5E20" Offset="0"/>
                    <GradientStop Color="#388E3C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="PiggyBank" Width="26" Height="26"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Savings Tracker" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Record and monitor your daily savings" FontSize="11" Foreground="#A5D6A7"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding LoadCommand}" Foreground="White" ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Summary cards + Add form -->
        <Grid Grid.Row="1" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <!-- Today's savings card -->
            <Border Grid.Column="0" CornerRadius="10" Margin="0,0,8,0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B5E20" Offset="0"/>
                        <GradientStop Color="#43A047" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TODAY'S SAVINGS" FontSize="10" Foreground="#A5D6A7" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TodaySavings, StringFormat='UGX {0:N0}'}"
                               FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Period total card -->
            <Border Grid.Column="1" CornerRadius="10" Margin="0,0,8,0" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D47A1" Offset="0"/>
                        <GradientStop Color="#1976D2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="PERIOD TOTAL" FontSize="10" Foreground="#90CAF9" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalSavings, StringFormat='UGX {0:N0}'}"
                               FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Add saving form -->
            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.10"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Amount (UGX)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Notes (optional)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1B5E20" BorderBrush="#1B5E20"
                            Foreground="White" Height="52" Padding="20,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="SAVE" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Filter + Table -->
        <Grid Grid.Row="2" Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter row -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B7280"/>
                    <DatePicker SelectedDate="{Binding FilterStartDate}" Width="130" Margin="0,0,16,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B7280"/>
                    <DatePicker SelectedDate="{Binding FilterEndDate}" Width="130" Margin="0,0,16,0"/>
                    <Button Content="Filter" Command="{Binding FilterCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#1B5E20" Foreground="#1B5E20" Height="36" Padding="16,0"/>
                </StackPanel>
            </Border>

            <!-- Savings table -->
            <Border Grid.Row="1" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Savings}"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='ddd d MMM yyyy'}" Width="160"/>
                        <DataGridTemplateColumn Header="Amount" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Amount, StringFormat='UGX {0:N0}'}"
                                               FontWeight="SemiBold" Foreground="#1B5E20"
                                               VerticalAlignment="Center" Margin="8,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        <DataGridTextColumn Header="Recorded By" Binding="{Binding UserName}" Width="140"/>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#EF5350" ToolTip="Delete">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="BusinessManager.App.Views.Savings.SavingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BusinessManager.App.ViewModels"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1100"
             Background="#F1F5F9"
             Loaded="SavingsView_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1B5E20" Offset="0"/>
                    <GradientStop Color="#388E3C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="PiggyBank" Width="26" Height="26"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Savings Tracker" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Track your daily savings by recipient" FontSize="11" Foreground="#A5D6A7"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding LoadCommand}" Foreground="White" ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Summary cards: Today + 3 recipients + Period total -->
        <Grid Grid.Row="1" Margin="16,14,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Today total -->
            <Border Grid.Column="0" CornerRadius="10" Margin="0,0,8,0" Padding="14,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B5E20" Offset="0"/>
                        <GradientStop Color="#43A047" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="TODAY" FontSize="9" Foreground="#A5D6A7" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TodaySavings, StringFormat='UGX {0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- OVALLA VALLENTINE -->
            <Border Grid.Column="1" CornerRadius="10" Margin="0,0,8,0" Padding="14,12"
                    Cursor="Hand">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4527A0" Offset="0"/>
                        <GradientStop Color="#7B1FA2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/></Border.Effect>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding FilterByRecipientCommand}"
                                  CommandParameter="OVALLA VALLENTINE"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="OVALLA VALLENTINE" FontSize="9" Foreground="#CE93D8" FontWeight="Bold"/>
                    <TextBlock Text="{Binding OvallaTotal, StringFormat='UGX {0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="(tap to filter)" FontSize="9" Foreground="#E1BEE7" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- BULE -->
            <Border Grid.Column="2" CornerRadius="10" Margin="0,0,8,0" Padding="14,12"
                    Cursor="Hand">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#BF360C" Offset="0"/>
                        <GradientStop Color="#E64A19" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/></Border.Effect>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding FilterByRecipientCommand}"
                                  CommandParameter="BULE"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="BULE" FontSize="9" Foreground="#FFCCBC" FontWeight="Bold"/>
                    <TextBlock Text="{Binding BuleTotal, StringFormat='UGX {0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="(tap to filter)" FontSize="9" Foreground="#FFCCBC" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- BANK -->
            <Border Grid.Column="3" CornerRadius="10" Margin="0,0,8,0" Padding="14,12"
                    Cursor="Hand">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D47A1" Offset="0"/>
                        <GradientStop Color="#1976D2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/></Border.Effect>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding FilterByRecipientCommand}"
                                  CommandParameter="BANK"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="BANK" FontSize="9" Foreground="#90CAF9" FontWeight="Bold"/>
                    <TextBlock Text="{Binding BankTotal, StringFormat='UGX {0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="(tap to filter)" FontSize="9" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Period total -->
            <Border Grid.Column="4" CornerRadius="10" Padding="14,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#37474F" Offset="0"/>
                        <GradientStop Color="#546E7A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="PERIOD TOTAL" FontSize="9" Foreground="#B0BEC5" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalSavings, StringFormat='UGX {0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Record new saving form -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Margin="16,12,16,0" Padding="16,14">
            <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/></Border.Effect>
            <StackPanel>
                <TextBlock Text="Record New Saving" FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Amount -->
                    <TextBox Grid.Column="0" Margin="0,0,10,0"
                             materialDesign:HintAssist.Hint="Amount (UGX) *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Recipient selector -->
                    <ComboBox Grid.Column="1" Margin="0,0,10,0"
                              materialDesign:HintAssist.Hint="Saving To *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              SelectedItem="{Binding SelectedRecipient}"
                              ItemsSource="{x:Static vm:SavingsViewModel.Recipients}"/>

                    <!-- Notes -->
                    <TextBox Grid.Column="2" Margin="0,0,10,0"
                             materialDesign:HintAssist.Hint="Notes (optional)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Save button -->
                    <Button Grid.Column="3" Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1B5E20" BorderBrush="#1B5E20"
                            Foreground="White" Height="52" Padding="20,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="RECORD SAVING" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Filter + Table -->
        <Grid Grid.Row="3" Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter row -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B7280"/>
                        <DatePicker SelectedDate="{Binding FilterStartDate}" Width="130" Margin="0,0,16,0"/>
                        <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B7280"/>
                        <DatePicker SelectedDate="{Binding FilterEndDate}" Width="130" Margin="0,0,16,0"/>
                        <Button Content="Refresh" Command="{Binding FilterCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#1B5E20" Foreground="#1B5E20" Height="36" Padding="14,0" Margin="0,0,16,0"/>
                    </StackPanel>
                    <!-- Recipient filter buttons -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#6B7280"/>
                        <Button Content="ALL" Height="34" Padding="14,0" Margin="0,0,6,0" FontSize="12"
                                Command="{Binding FilterByRecipientCommand}" CommandParameter="ALL">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="Foreground" Value="#374151"/>
                                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterRecipient}" Value="ALL">
                                            <Setter Property="Background" Value="#374151"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="OVALLA" Height="34" Padding="14,0" Margin="0,0,6,0" FontSize="12"
                                Command="{Binding FilterByRecipientCommand}" CommandParameter="OVALLA VALLENTINE">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="Foreground" Value="#7B1FA2"/>
                                    <Setter Property="BorderBrush" Value="#7B1FA2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterRecipient}" Value="OVALLA VALLENTINE">
                                            <Setter Property="Background" Value="#7B1FA2"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="BULE" Height="34" Padding="14,0" Margin="0,0,6,0" FontSize="12"
                                Command="{Binding FilterByRecipientCommand}" CommandParameter="BULE">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="Foreground" Value="#E64A19"/>
                                    <Setter Property="BorderBrush" Value="#E64A19"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterRecipient}" Value="BULE">
                                            <Setter Property="Background" Value="#E64A19"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="BANK" Height="34" Padding="14,0" FontSize="12"
                                Command="{Binding FilterByRecipientCommand}" CommandParameter="BANK">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="Foreground" Value="#1565C0"/>
                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterRecipient}" Value="BANK">
                                            <Setter Property="Background" Value="#1565C0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Savings table -->
            <Border Grid.Row="1" Background="White" CornerRadius="10">
                <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/></Border.Effect>
                <DataGrid ItemsSource="{Binding Savings}"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='ddd d MMM yyyy'}" Width="160"/>
                        <DataGridTemplateColumn Header="Recipient" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="10,4" Margin="4,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8EAF6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Recipient}" Value="OVALLA VALLENTINE">
                                                        <Setter Property="Background" Value="#EDE7F6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Recipient}" Value="BULE">
                                                        <Setter Property="Background" Value="#FBE9E7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Recipient}" Value="BANK">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Recipient}" FontWeight="SemiBold" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Recipient}" Value="OVALLA VALLENTINE">
                                                            <Setter Property="Foreground" Value="#6A1B9A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Recipient}" Value="BULE">
                                                            <Setter Property="Foreground" Value="#BF360C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Recipient}" Value="BANK">
                                                            <Setter Property="Foreground" Value="#0D47A1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Amount" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Amount, StringFormat='UGX {0:N0}'}"
                                               FontWeight="Bold" FontSize="13" Foreground="#1B5E20"
                                               VerticalAlignment="Center" Margin="8,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        <DataGridTextColumn Header="Recorded By" Binding="{Binding UserName}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
